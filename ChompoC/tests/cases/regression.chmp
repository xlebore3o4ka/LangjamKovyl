print(Int("42"), "\n");
print(Int(3.9), "\n");
print(Int(NULL), "\n");
print(Double("2.5"), "\n");
print(Double(true), "\n");
print(Bool(NULL), " ", Bool(Array{}), " ", Bool(Array{0}), "\n");
print(Char(65), " ", Int('A'), "\n");
print(CATS(Array{'a', 'b'}), "\n");
print(Array("ab"), "\n");
print(Type(NULL), " ", Type(1), " ", Type(1.5), " ", Type('x'), " ", Type("x"), " ", Type(Array{}), "\n");

var calls = 0;

fun mark(value) {
    calls++;
    return value;
}

print(false && mark(true), " ", calls, "\n");
print(true || mark(false), " ", calls, "\n");
print(true && mark(true), " ", calls, "\n");
print(false || mark(false), " ", calls, "\n");

print(1 == true, " ", 65 == 'A', " ", 1.0 == true, "\n");
print(Array{1, Array{2}} == Array{true, Array{2.0}}, "\n");
print(Array{1, 2} != Array{1, 3}, "\n");

var iterable_calls = 0;

fun make_values() {
    iterable_calls++;
    return Array{1, 2};
}

for (var value in make_values())
    print(value, "\n");

print("iterable_calls:", iterable_calls, "\n");

var outer = 99;

for (var outer in Array{4, 5})
    print("inner:", outer, "\n");

print("outer:", outer, "\n");

for (var ignored in Array{})
    print("unreachable-array\n");

for (var ignored in "")
    print("unreachable-string\n");

for (var first in Array{1, 2}) {
    for (var second in Array{1, 2, 3}) {
        if (second == 2)
            continue;

        if (first == 2 && second == 3)
            break;

        print(first, ":", second, "\n");
    }
}

var matrix = Array{Array{1, 2}, Array{3, 4}};
matrix[1][0] += 7;
matrix[0][1]++;
print(matrix, "\n");

var text = "abc";
text[1] = 'Z';
text[2]--;
print(text, "\n");

fun truth(value) {
    if (value)
        return true;

    return false;
}

print(truth(NULL), " ", truth(0), " ", truth(0.0), " ", truth(""), " ", truth(Array{}), " ", truth('\0'), "\n");
print(truth(1), " ", truth(-1), " ", truth("x"), " ", truth(Array{NULL}), " ", truth('A'), "\n");

{
  "name": "clx",
  "displayName": "CL++ language support",
  "version": "0.1.0",
  "description": "",
  "categories": [
    "Programming Languages"
  ],
  "license": "MIT",
  "publisher": "TraumDE",
  "type": "module",
  "l10n": "./l10n",
  "scripts": {
    "compile": "tsc",
    "build": "vsce package",
    "lint": "oxlint ./src",
    "lint:fix": "oxlint --fix ./src",
    "fmt": "oxfmt ./src",
    "fmt:check": "oxfmt --check ./src"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@vscode/vsce": "^3.9.2",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.3"
  },
  "contributes": {
    "languages": [
      {
        "id": "clx",
        "aliases": [
          "CL++",
          "clx"
        ],
        "extensions": [
          ".clx"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./assets/icon.svg",
          "dark": "./assets/icon.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "clx",
        "scopeName": "source.clx",
        "path": "./syntaxes/clx.tmLanguage.json"
      }
    ]
  },
  "engines": {
    "vscode": "^1.125.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
